# ============================================
# Sensident — Configuration dev local
# ============================================
# Copie ce fichier en .env et remplis les valeurs

# --- Database (PostgreSQL en prod, SQLite en dev par defaut) ---
# Dev local (SQLite, par defaut) :
DATABASE_URL=file:./dev.db
# Prod (Neon ou hebergeur HDS) — DOIT inclure sslmode=require :
# DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require

# --- Auth.js ---
# Genere avec: openssl rand -base64 32
AUTH_SECRET=dev-only-secret-replace-in-prod-xxxxxxxxxxxxxxxxxxx
AUTH_URL=http://localhost:3000

# --- Email (Brevo SMTP en prod, JSON en dev) ---
# En dev, NODE_ENV=development => transport JSON dans la console
# En prod, utiliser SMTP Brevo (smtp-relay.brevo.com:587)
BREVO_SMTP_USER=noreply@sensident.fr
BREVO_SMTP_PASS=xsmtpsib-xxxxxxxxxxxx
BREVO_WEBHOOK_SECRET=openssl-rand-base64-32
EMAIL_FROM="Sensident <noreply@sensident.fr>"

# --- Stripe (test mode en dev) ---
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_COUPON_AMBASSADOR=AMBASSADOR_2026

# --- Cron keep-alive (anti scale-to-zero Neon en prod) ---
# Genere avec: openssl rand -base64 32
CRON_SECRET=openssl-rand-base64-32

# --- Unsubscribe token secret (HMAC des liens de desabonnement) ---
UNSUBSCRIBE_SECRET=openssl-rand-base64-32

# --- IP hash salt (audit logs) ---
IP_HASH_SALT=openssl-rand-base64-32

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
